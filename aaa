local function applyPerformanceSettings()
    local lighting = game:GetService("Lighting")
    if Config.DesabilitarParticulas then
        safeCall(function()
            for _, obj in ipairs(Workspace:GetDescendants()) do
                if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") then
                    obj.Enabled = false
                end
            end
        end)
    end
    if Config.GraficosBaixos then
        safeCall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
    end
    if Config.DesabilitarSombras then
        safeCall(function() lighting.GlobalShadows = false end)
    end
    if Config.ReduzirDistancia then
        safeCall(function()
            Workspace.StreamingEnabled = true
            Workspace.StreamingMinRadius = 32
            Workspace.StreamingTargetRadius = 64
        end)
    end
end

