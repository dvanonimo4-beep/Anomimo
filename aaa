local function criarToggle(parent, texto, y, varName, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 24)
    btn.Position = UDim2.new(0.05, 0, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
    btn.BackgroundTransparency = 0.15
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Cores.Texto
    btn.Text = "◯ " .. texto .. ": OFF"
    btn.TextColor3 = Cores.Texto
    btn.TextSize = 10
    btn.Font = Enum.Font.GothamMedium
    btn.Parent = parent
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, 5)
    c.Parent = btn
    local state = false
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = (state and "⬤ " or "◯ ") .. texto .. ": " .. (state and "ON" or "OFF")
        btn.BackgroundColor3 = state and Color3.fromRGB(40, 130, 40) or Color3.fromRGB(40, 40, 60)
        btn.BorderColor3 = state and Color3.fromRGB(0, 255, 100) or Cores.Texto
        if varName then Config[varName] = state end
        if callback then callback(state) end
        print("🔘 " .. texto .. ":", state and "ON" or "OFF")
    end)
    return btn
end

local function criarSlider(parent, texto, y, default, min, max, varName, callback)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0.9, 0, 0, 24)
    frame.Position = UDim2.new(0.05, 0, 0, y)
    frame.BackgroundTransparency = 1
    frame.Parent = parent

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.5, 0, 0.5, 0)
    label.Position = UDim2.new(0, 0, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = texto .. ": " .. default
    label.TextColor3 = Cores.TextoClaro
    label.TextSize = 9
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Font = Enum.Font.GothamMedium
    label.Parent = frame

    local val = default
    local menos = Instance.new("TextButton")
    menos.Size = UDim2.new(0, 20, 0, 16)
    menos.Position = UDim2.new(0.7, 0, 0.5, 0)
    menos.BackgroundColor3 = Cores.Vermelho
    menos.BackgroundTransparency = 0.2
    menos.Text = "−"
    menos.TextColor3 = Cores.Texto
    menos.TextSize = 10
    menos.Font = Enum.Font.GothamBold
    menos.Parent = frame
    local c1 = Instance.new("UICorner")
    c1.CornerRadius = UDim.new(0, 4)
    c1.Parent = menos

    local mais = Instance.new("TextButton")
    mais.Size = UDim2.new(0, 20, 0, 16)
    mais.Position = UDim2.new(0.87, 0, 0.5, 0)
    mais.BackgroundColor3 = Cores.Verde
    mais.BackgroundTransparency = 0.2
    mais.Text = "+"
    mais.TextColor3 = Cores.Texto
    mais.TextSize = 10
    mais.Font = Enum.Font.GothamBold
    mais.Parent = frame
    local c2 = Instance.new("UICorner")
    c2.CornerRadius = UDim.new(0, 4)
    c2.Parent = mais

    local function atualizar()
        val = math.clamp(val, min, max)
        label.Text = texto .. ": " .. val
        if varName then Config[varName] = val end
        if callback then callback(val) end
        print("🔘 " .. texto .. ":", val)
    end

    menos.MouseButton1Click:Connect(function()
        val = math.max(min, val - 1)
        atualizar()
    end)
    mais.MouseButton1Click:Connect(function()
        val = math.min(max, val + 1)
        atualizar()
    end)
    return frame
end

